# Database（本地与 Compose 共用账号密码；本地 uvicorn 需显式 DATABASE_URL 指向宿主机）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=paper_archive
# 映射到宿主机的端口（本机 psql / uvicorn 用 POSTGRES_HOST:POSTGRES_PORT）
POSTGRES_PORT=5432
# 本机跑 uvicorn：须为 127.0.0.1（或本机 IP），不要使用 db（Compose 网络内主机名）；Compose 内由 docker-compose 覆盖为 db
POSTGRES_HOST=127.0.0.1

# Backend
BACKEND_PORT=8000
APP_SECRET_KEY=HzQayhaBXUSqEbl70t6nxA
PUBLIC_ORIGIN=https://researchdock.shskkj.net
COOKIE_SECURE=true

# Internal nginx entry（供宿主机 Nginx 反向代理）
FRONTEND_PORT=8080

# n8n
GENERIC_TIMEZONE=UTC

# File storage path on host (used in later milestones; optional for M1)
FILE_STORAGE_PATH=./data/files

# AI / Queue
REDIS_URL=redis://localhost:6379/1
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=false

# Chat LLM
LLM_PROVIDER=glm
# 对话与论文摘要等 chat/completions 的超时（秒）；嵌入仍用 OPENAI_TIMEOUT_SECONDS / GLM_TIMEOUT_SECONDS
LLM_CHAT_TIMEOUT_SECONDS=300
LLM_CHAT_MAX_RETRIES=2
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
GLM_API_KEY=0654b24cd6124a3ebe0d319df29852a5.9eoqXmlgYRC9tXdK
GLM_MODEL=glm-4.7
GLM_TIMEOUT_SECONDS=120
GLM_VERIFY_SSL=true

# Embedding / Rerank
EMBEDDING_PROVIDER=glm
OPENAI_EMBEDDING_MODEL=
OPENAI_TIMEOUT_SECONDS=120
OPENAI_VERIFY_SSL=true
GLM_EMBEDDING_MODEL=embedding-3
GLM_EMBEDDING_DIMENSIONS=1024
GLM_RERANK_MODEL=rerank

# Retrieval
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5
RAG_SPARSE_TOP_K=20
RAG_DENSE_TOP_K=20
RAG_FUSION_WINDOW=20
RAG_RRF_K=60
RAG_RERANK_TOP_N=10
RAG_TEXT_SEARCH_CONFIG=simple

# OCR
OCR_PROVIDER=glm_ocr
LLM_OCR_BASE_URL=https://api.z.ai/api/paas/v4/layout_parsing
LLM_OCR_API_KEY=278f6024c3a54cbc880b8c879e355c35.gtRdjsOHRxw7ZikW
LLM_OCR_MODEL=glm-ocr
LLM_OCR_TIMEOUT_SECONDS=180
LLM_OCR_MAX_RETRIES=2
LLM_OCR_RETRY_BACKOFF_SECONDS=0.5
LLM_OCR_VERIFY_SSL=true
OCR_FORCE_FULL_DOCUMENT=true

# ACR / image publishing
ACR_REGISTRY=toms-acr-registry.cn-shanghai.cr.aliyuncs.com
IMAGE_NAMESPACE=researchdock
IMAGE_TAG=latest
