# Database（本地与 Compose 共用；后端按分项拼接 DATABASE_URL，改密码/端口只改此处即可）
POSTGRES_USER=paper_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=paper_archive
# 映射到宿主机的端口（本机 psql / uvicorn 用 POSTGRES_HOST:POSTGRES_PORT）
POSTGRES_PORT=5432
# 本机跑 uvicorn：须为 127.0.0.1（或本机 IP），不要使用 db（Compose 网络内主机名）；Compose 内由 docker-compose 覆盖为 db
POSTGRES_HOST=127.0.0.1
# 可选：整串覆盖（高级用法）；留空或未设置时使用上面分项自动拼接
# DATABASE_URL=

# Backend
BACKEND_PORT=8000
APP_SECRET_KEY=please_change_me_in_production
# 服务器部署请改成 https://your-domain
PUBLIC_ORIGIN=https://example.com
COOKIE_SECURE=true

# Internal nginx entry（供宿主机 Nginx 反向代理；建议仅监听本机回环）
FRONTEND_PORT=8080

# n8n
GENERIC_TIMEZONE=UTC

# File storage path on host (used in later milestones; optional for M1)
FILE_STORAGE_PATH=./data/files

# AI / Queue
REDIS_URL=redis://localhost:6379/1
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=false

# Chat LLM
LLM_PROVIDER=auto
# 对话与论文摘要等 chat/completions 的超时（秒）；嵌入仍用 OPENAI_TIMEOUT_SECONDS / GLM_TIMEOUT_SECONDS
LLM_CHAT_TIMEOUT_SECONDS=300
LLM_CHAT_MAX_RETRIES=2
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
GLM_MODEL=glm-4.7
GLM_TIMEOUT_SECONDS=120
GLM_VERIFY_SSL=true

# Embedding / Rerank
EMBEDDING_PROVIDER=auto
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=120
OPENAI_VERIFY_SSL=true
GLM_EMBEDDING_MODEL=embedding-3
GLM_EMBEDDING_DIMENSIONS=1024
GLM_RERANK_MODEL=rerank

# Retrieval
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5
RAG_SPARSE_TOP_K=20
RAG_DENSE_TOP_K=20
RAG_FUSION_WINDOW=20
RAG_RRF_K=60
RAG_RERANK_TOP_N=10
RAG_TEXT_SEARCH_CONFIG=simple

# Document parsing / picture descriptions
DOCUMENT_EXTRACTOR=docling
DOCLING_DO_OCR=true
DOCLING_DO_TABLE_STRUCTURE=true
DOCLING_DO_PICTURE_DESCRIPTION=true
DOCLING_OCR_ENGINE=easyocr
DOCLING_OCR_LANGUAGES=ch_sim,en
DOCLING_FORCE_FULL_PAGE_OCR=true
DOCLING_GENERATE_PICTURE_IMAGES=true
DOCLING_IMAGES_SCALE=2.0
DOCLING_DOCUMENT_TIMEOUT_SECONDS=240
DOCLING_DEVICE=auto
# 模型缓存（本机开发默认 ./data/models；Compose 内 worker 挂载卷 /data/models）
MODEL_CACHE_PATH=./data/models
# 留空则使用 MODEL_CACHE_PATH 下子目录 docling / easyocr / huggingface
DOCLING_ARTIFACTS_PATH=
EASYOCR_MODULE_PATH=
HF_HOME=
PICTURE_VLM_PROVIDER=glm_4_6v
PICTURE_VLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
PICTURE_VLM_API_KEY=
PICTURE_VLM_MODEL=glm-4.6v
PICTURE_VLM_TIMEOUT_SECONDS=120
PICTURE_VLM_MAX_RETRIES=2
PICTURE_VLM_PROMPT_VERSION=picture-rag-v1

# ACR / image publishing
ACR_REGISTRY=
IMAGE_NAMESPACE=researchdock
IMAGE_TAG=latest
