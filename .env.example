# Database（本地与 Compose 共用账号密码；本地 uvicorn 需显式 DATABASE_URL 指向宿主机）
POSTGRES_PASSWORD=change_me
# 数据库映射到宿主机端口，便于本机 psql / 本地 uvicorn 用 127.0.0.1 连接
POSTGRES_PORT=5432

# 后端直连数据库：host 须为 127.0.0.1 或本机 IP，端口与 POSTGRES_PORT 一致；不要使用主机名 db（db 仅在 Compose 网络内可解析）。
# Compose 启动 backend 容器时会注入 DATABASE_URL=...@db:5432，不依赖本行。
DATABASE_URL=postgresql://paper_user:change_me@127.0.0.1:5432/paper_archive

# Backend
BACKEND_PORT=8000
APP_SECRET_KEY=please_change_me_in_production
FRONTEND_ORIGIN=http://localhost:3000
COOKIE_SECURE=false

# Frontend (browser calls backend on host port)
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_N8N_URL=http://localhost:5678

# n8n
N8N_PORT=5678
N8N_HOST=0.0.0.0
GENERIC_TIMEZONE=UTC

# File storage path on host (used in later milestones; optional for M1)
FILE_STORAGE_PATH=./data/files
